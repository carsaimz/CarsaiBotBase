<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground"
    android:paddingBottom="8dp">

    <!-- Current URL header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp">
        <ImageView android:id="@+id/more_sec_icon"
            android:layout_width="16dp" android:layout_height="16dp"
            android:src="@drawable/ic_lock" android:layout_marginEnd="8dp"/>
        <TextView android:id="@+id/more_url"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp" android:textColor="?android:attr/textColorPrimary"
            android:singleLine="true" android:ellipsize="middle"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/border"/>

    <!-- Actions grid — 4 per row -->
    <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:columnCount="4" android:padding="8dp">

        <LinearLayout android:id="@+id/more_bookmark"
            android:layout_width="0dp" android:layout_height="72dp"
            android:layout_columnWeight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:id="@+id/more_bookmark_icon"
                android:layout_width="28dp" android:layout_height="28dp"
                android:src="@drawable/ic_bookmark_border" android:tint="@color/accent"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Bookmark" android:textSize="11sp"
                android:textColor="?android:attr/textColorSecondary" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/more_share"
            android:layout_width="0dp" android:layout_height="72dp"
            android:layout_columnWeight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                android:src="@drawable/ic_share" android:tint="@color/accent"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Share" android:textSize="11sp"
                android:textColor="?android:attr/textColorSecondary" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/more_copy_url"
            android:layout_width="0dp" android:layout_height="72dp"
            android:layout_columnWeight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                android:src="@drawable/ic_copy" android:tint="@color/accent"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Copy URL" android:textSize="11sp"
                android:textColor="?android:attr/textColorSecondary" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/more_find"
            android:layout_width="0dp" android:layout_height="72dp"
            android:layout_columnWeight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                android:src="@drawable/ic_find" android:tint="@color/accent"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Find" android:textSize="11sp"
                android:textColor="?android:attr/textColorSecondary" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/more_open_app"
            android:layout_width="0dp" android:layout_height="72dp"
            android:layout_columnWeight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                android:src="@drawable/ic_open_new" android:tint="@color/accent"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Open in app" android:textSize="11sp"
                android:textColor="?android:attr/textColorSecondary" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/more_desktop"
            android:layout_width="0dp" android:layout_height="72dp"
            android:layout_columnWeight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:id="@+id/more_desktop_icon"
                android:layout_width="28dp" android:layout_height="28dp"
                android:src="@drawable/ic_desktop" android:tint="@color/accent"/>
            <TextView android:id="@+id/more_desktop_label"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Desktop" android:textSize="11sp"
                android:textColor="?android:attr/textColorSecondary" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/more_bookmarks_list"
            android:layout_width="0dp" android:layout_height="72dp"
            android:layout_columnWeight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                android:src="@drawable/ic_bookmark" android:tint="@color/accent"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Bookmarks" android:textSize="11sp"
                android:textColor="?android:attr/textColorSecondary" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/more_clear"
            android:layout_width="0dp" android:layout_height="72dp"
            android:layout_columnWeight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                android:src="@drawable/ic_clear_all" android:tint="#F44336"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Clear" android:textSize="11sp"
                android:textColor="#F44336" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/more_settings"
            android:layout_width="0dp" android:layout_height="72dp"
            android:layout_columnWeight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                android:src="@drawable/ic_settings" android:tint="@color/accent"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Settings" android:textSize="11sp"
                android:textColor="?android:attr/textColorSecondary" android:layout_marginTop="4dp"/>
        </LinearLayout>

    </GridLayout>
</LinearLayout>
